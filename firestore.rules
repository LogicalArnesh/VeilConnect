rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/adminRoster/$(request.auth.uid));
    }

    // Team member profiles
    match /userProfiles/{userId} {
      allow read: if true; 
      // Users can update their own authUid during login, or admins can manage all
      allow write: if true; 
    }
    
    // Administrative Roster (Security Index)
    match /adminRoster/{authId} {
      allow read: if true;
      allow write: if request.auth.uid == authId;
    }
    
    // 2FA and Security codes
    match /verificationCodes/{userId} {
      allow read, write: if true; 
    }
    
    // Public confessions - anyone can create, admins can read/update/delete
    match /confessions/{confessionId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdmin() || true; // Temporary true for migration, then switch to just isAdmin()
    }
    
    // User presence
    match /presence/{userId} {
      allow read, write: if true;
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isAdmin(); 
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}